# Chorus Auth Control Plane MVP Configuration
# Copy this file to .env and fill in live credentials only when leaving mock mode.

# Core runtime
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./data/chorus.db

# Demo seeding
SEED_DEMO=true
SEED_ON_STARTUP=true
QUARANTINE_AFTER_BLOCKED_REQUESTS=2

# Auth, vault, and provider adapters
AUTH_MODE=mock
VAULT_MODE=mock
PROVIDER_MODE=mock

# Optional Gemini risk explanations
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview

# Optional live Auth0 and Token Vault credentials
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
TOKEN_VAULT_AUDIENCE=
TOKEN_VAULT_CLIENT_ID=
TOKEN_VAULT_CLIENT_SECRET=
